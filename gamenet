        }
        if (r.status === 'closed') { totalDayIncome += r.totalAmount; closedCount++; }
        csvContent += `${r.table},${r.consoleType},${r.mode},${r.timeStart},${timeEndStr},${r.gameCost},${cafeDetails},${r.cafeCost},${finalAmount},${statusFa}\n`;
    });
    csvContent += `\n,,,تعداد رکوردهای بسته:,${closedCount},,,مجموع درآمد روز:,${totalDayIncome}\n`;
    const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
    const link = document.createElement("a");
    const url = URL.createObjectURL(blob);
    const dateFa = new Date().toLocaleDateString('fa-IR').replace(/\//g, '-');
    link.setAttribute("href", url); link.setAttribute("download", `گزارش_${day}_${dateFa}.csv`);
    link.style.visibility = 'hidden'; document.body.appendChild(link); link.click(); document.body.removeChild(link);
}

function clearDay() { 
    if(confirm('پاکسازی کل روز؟ (موجودی کافه باز نمی‌گردد)')) { 
        gameNet[daySelect.value] = []; 
        saveSettingsToStorage();
        render(); 
    } 
}

function addCafeItem() {
    let n = document.getElementById('newCafeName').value;
    let p = parseInt(document.getElementById('newCafePrice').value);
    let st = parseInt(document.getElementById('newCafeStock').value);
    if(n && p > 0 && st >= 0) {
        cafeMenu.push({ id: Date.now(), name: n, price: p, stock: st });
        document.getElementById('newCafeName').value = ''; document.getElementById('newCafePrice').value = ''; document.getElementById('newCafeStock').value = ''; 
        saveSettingsToStorage();
        renderCafeMenus();
    }
}

function deleteCafeItem(idx) { 
    if(confirm('آیا از حذف این آیتم از منو مطمئن هستید؟')) { 
        cafeMenu.splice(idx, 1); 
        saveSettingsToStorage();
        renderCafeMenus(); 
    }
}

function neonFlash() { 
    document.getElementById('mainContainer').style.boxShadow = '0 0 40px var(--primary)'; 
    setTimeout(() => document.getElementById('mainContainer').style.boxShadow = '', 500); 
}

daySelect.onchange = render;

// ==========================================
// توابع مربوط به ویرایش انبار کافه
// ==========================================
function editCafeItem(index) {
    const item = cafeMenu[index];
    document.getElementById('newCafeName').value = item.name;
    document.getElementById('newCafePrice').value = item.price;
    document.getElementById('newCafeStock').value = item.stock;
    const addBtn = document.querySelector('button[onclick="addCafeItem()"]');
    if(addBtn) {
        addBtn.textContent = 'به‌روزرسانی';
        addBtn.setAttribute('onclick', `updateCafeItem(${index})`);
        addBtn.classList.replace('btn-primary', 'btn-success');
    }
}

function updateCafeItem(index) {
    const name = document.getElementById('newCafeName').value;
    const price = document.getElementById('newCafePrice').value;
    const stock = document.getElementById('newCafeStock').value;
    if(name && price && stock) {
        cafeMenu[index].name = name;
        cafeMenu[index].price = parseInt(price);
        cafeMenu[index].stock = parseInt(stock);
        saveSettingsToStorage();
        renderCafeMenus();
        resetCafeModalBtn();
    } else {
        alert("لطفاً تمام فیلدها را پر کنید.");
    }
}

function resetCafeModalBtn() {
    document.getElementById('newCafeName').value = '';
    document.getElementById('newCafePrice').value = '';
    document.getElementById('newCafeStock').value = '';
    const updateBtn = document.querySelector('button[onclick^="updateCafeItem"]');
    if(updateBtn) {
        updateBtn.textContent = 'افزودن آیتم';
        updateBtn.setAttribute('onclick', 'addCafeItem()');
        updateBtn.classList.replace('btn-success', 'btn-primary');
    }
}

// ==========================================
// سیستم یادآوری زمان رزرو 
// ==========================================
function checkAndStartReservations() {
    const now = new Date();
    const currentHour = now.getHours();
    const currentMinute = now.getMinutes();
    const currentTimeStr = `${currentHour.toString().padStart(2, '0')}:${currentMinute.toString().padStart(2, '0')}`;
    
    const day = document.getElementById('daySelect').value;
    if (!gameNet[day]) return;

    gameNet[day].forEach((session) => {
        if (session.status === 'reserved' && session.timeStart === currentTimeStr) {
            alert(`⏰ یادآوری رزرو!\nمیز شماره: ${session.table}\nنام: ${session.customerName || 'ثبت نشده'}\nشماره: ${session.customerPhone || 'ثبت نشده'}\nساعت: ${session.timeStart}`);
        }
    });
}

setInterval(checkAndStartReservations, 60000); 
setTimeout(checkAndStartReservations, 1000);

// ==========================================
// آپدیت زنده ساعت ورود
// ==========================================
setInterval(() => {
    const timeInput = document.getElementById('timeStart');
    if (timeInput && document.activeElement !== timeInput) {
        const now = new Date();
        const hrs = now.getHours().toString().padStart(2, '0');
        const mins = now.getMinutes().toString().padStart(2, '0');
        timeInput.value = `${hrs}:${mins}`;
    }
}, 1000);

</script>

