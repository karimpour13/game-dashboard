function saveEdit() {
    let s = gameNet[daySelect.value][editingIndex];
    s.timeStart = document.getElementById('editTimeStart').value;
    let consoleSelect = document.getElementById('editConsoleSelect');
    if(consoleSelect) s.consoleType = consoleSelect.value;
    s.mode = document.getElementById('editModeSelect').value;
    
    if(s.status === 'closed') {
        let newEnd = document.getElementById('editTimeEnd').value;
        if(newEnd) s.timeEnd = newEnd;
    }

    s.cafeCost = 0;
    let newCafeItems = [];
    s.cafeItems.forEach(oldItem => {
        if(!cafeMenu.find(c => c.id === oldItem.id)) {
            newCafeItems.push(oldItem); s.cafeCost += (oldItem.qty * oldItem.price);
        }
    });

    cafeMenu.forEach(item => {
        let input = document.getElementById('edit_cafe_qty_' + item.id);
        if(input) {
            let newQty = parseInt(input.value) || 0;
            let ordered = s.cafeItems.find(c => c.id === item.id);
            let oldQty = ordered ? ordered.qty : 0;
            let delta = newQty - oldQty; 
            item.stock -= delta; 
            if(newQty > 0) {
                newCafeItems.push({ id: item.id, name: item.name, price: item.price, qty: newQty });
                s.cafeCost += (newQty * item.price);
            }
        }
    });
    s.cafeItems = newCafeItems;

    if(s.status === 'closed') {
        let calc = calculateCost(s.timeStart, s.timeEnd, s.consoleType, s.mode, s.cafeCost, s.table);
        s.hours = calc.durationStr;
        s.gameCost = calc.gameCost;
        s.totalAmount = calc.total;
    }
    saveSettingsToStorage();
    closeEditModal(); render(); renderCafeMenus();
}

