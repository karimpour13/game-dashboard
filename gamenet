<script>
    // ================== تنظیمات امنیتی (جلوگیری از کپی و مشاهده سورس) ==================
// جلوگیری از راست‌کلیک
document.addEventListener('contextmenu', function(e) {
    e.preventDefault();
});

// جلوگیری از کلیدهای میانبر متداول برای باز کردن ابزارهای توسعه‌دهنده و سورس
document.addEventListener('keydown', function(e) {
    if (e.key === 'F12') { e.preventDefault(); } // F12
    if (e.ctrlKey && e.shiftKey && e.key === 'I') { e.preventDefault(); } // Ctrl+Shift+I
    if (e.ctrlKey && e.shiftKey && e.key === 'J') { e.preventDefault(); } // Ctrl+Shift+J
    if (e.ctrlKey && e.key === 'u' || e.ctrlKey && e.key === 'U') { e.preventDefault(); } // Ctrl+U
    if (e.ctrlKey && e.key === 's' || e.ctrlKey && e.key === 'S') { e.preventDefault(); } // Ctrl+S
});
// ====================================================================================

// ================== سیستم لاگین ==================
function checkLogin() {
    const user = document.getElementById('loginUsername').value;
    const pass = document.getElementById('loginPassword').value;

    if (user === 'admin' && pass === '1234') {
        document.getElementById('loginScreen').style.display = 'none';
        document.getElementById('appScreen').style.display = 'block';
        
        // بررسی اینکه اگر پس‌زمینه ویدیو است، متوقف شود (جلوگیری از ارور برای عکس)
        const bgMedia = document.querySelector('.login-video-bg');
        if(bgMedia && bgMedia.tagName === 'VIDEO') bgMedia.pause();

        initSystem(); 
    } else {
        alert('❌ نام کاربری یا رمز عبور اشتباه است!');
    }
}

function logout() {
    if(confirm("آیا از خروج مطمئن هستید؟")) {
        document.getElementById('loginUsername').value = '';
        document.getElementById('loginPassword').value = '';
        document.getElementById('loginScreen').style.display = 'flex';
        document.getElementById('appScreen').style.display = 'none';
        
        const bgMedia = document.querySelector('.login-video-bg');
        if(bgMedia && bgMedia.tagName === 'VIDEO') bgMedia.play();
    }
}

document.getElementById('loginPassword').addEventListener('keypress', function (e) {
    if (e.key === 'Enter') checkLogin();
});

// ================== سیستم مدیریت گیم نت ==================
const DAYS = ["یکشنبه", "دوشنبه", "سه‌شنبه", "چهارشنبه", "پنجشنبه", "جمعه", "شنبه"];
let TOTAL_TABLES = 10;

let PRICING = {
    "PS4": { "1 دسته": 50000, "2 دسته": 60000, "3 دسته": 80000, "4 دسته": 100000 },
    "PS5": { "1 دسته": 70000, "2 دسته": 80000, "3 دسته": 100000, "4 دسته": 120000 },
    "Xbox": { "1 دسته": 60000, "2 دسته": 70000, "3 دسته": 90000, "4 دسته": 110000 },
    "PC": { "معمولی": 80000, "VIP": 100000 },
    "VIP": { "1 دسته": 100000, "2 دسته": 120000, "3 دسته": 150000, "4 دسته": 180000 }
};

let TABLE_CONFIGS = {};
for(let i=1; i<=TOTAL_TABLES; i++) {
    TABLE_CONFIGS[i] = { console: 'PS4', isVip: false };
}

let cafeMenu = [
    { id: 1, name: "اسپرسو", price: 50000, stock: 50 },
    { id: 2, name: "آب معدنی", price: 15000, stock: 100 },
    { id: 3, name: "چای", price: 30000, stock: 200 }
];
let gameNet = {}; 
DAYS.forEach(day => gameNet[day] = []);

let activeModalSessionIndex = -1;
let editingIndex = -1;
let currentDateString = "";
let timerInterval = null; 

const daySelect = document.getElementById('daySelect');
const tableSelect = document.getElementById('tableSelect');
const timeStart = document.getElementById('timeStart');
const sessionsBody = document.getElementById('sessionsBody');

// ================== توابع ذخیره و بازیابی ==================
function loadSettings() {
    const savedConfigs = localStorage.getItem('TABLE_CONFIGS');
    const savedPricing = localStorage.getItem('PRICING');
    const savedTotalTables = localStorage.getItem('TOTAL_TABLES');
    const savedCafe = localStorage.getItem('CAFE_MENU');
    const savedGameNet = localStorage.getItem('GAME_NET_DATA');

    if (savedConfigs) TABLE_CONFIGS = JSON.parse(savedConfigs);
    if (savedPricing) PRICING = JSON.parse(savedPricing);
    if (savedTotalTables) TOTAL_TABLES = parseInt(savedTotalTables);
    if (savedCafe) cafeMenu = JSON.parse(savedCafe);
    if (savedGameNet) {
        gameNet = JSON.parse(savedGameNet);
    } else {
        DAYS.forEach(day => gameNet[day] = []);
    }

    if (!PRICING["Xbox"]) PRICING["Xbox"] = { "1 دسته": 60000, "2 دسته": 70000, "3 دسته": 90000, "4 دسته": 110000 };
    if (!PRICING["PC"]) PRICING["PC"] = { "1 دسته": 80000, "2 دسته": 100000, "3 دسته": 120000, "4 دسته": 150000 };
    if (!PRICING["VIP"]) PRICING["VIP"] = { "1 دسته": 100000, "2 دسته": 120000, "3 دسته": 150000, "4 دسته": 180000 };
}

function saveSettingsToStorage() {
    localStorage.setItem('TABLE_CONFIGS', JSON.stringify(TABLE_CONFIGS));
    localStorage.setItem('PRICING', JSON.stringify(PRICING));
    localStorage.setItem('TOTAL_TABLES', TOTAL_TABLES.toString());
    localStorage.setItem('CAFE_MENU', JSON.stringify(cafeMenu));
    localStorage.setItem('GAME_NET_DATA', JSON.stringify(gameNet));
}

// ================== مدیریت پاپ‌آپ‌های تنظیمات ==================
function openSettingsModal(modalId) {
    document.getElementById(modalId).style.display = 'flex';
}

function closeSettingsModal(modalId) {
    document.getElementById(modalId).style.display = 'none';
}

function toggleTheme() {
    const body = document.body;
    if (body.getAttribute('data-theme') === 'light') {
        body.removeAttribute('data-theme');
    } else {
        body.setAttribute('data-theme', 'light');
    }
}

function initSystem() {
    loadSettings(); 
    
    daySelect.innerHTML = ''; 
    const displayDays = ["شنبه", "یکشنبه", "دوشنبه", "سه‌شنبه", "چهارشنبه", "پنجشنبه", "جمعه"];
    displayDays.forEach(day => daySelect.appendChild(new Option(day, day)));
    
    generateTableSelect();
    
    const today = new Date();
    const todayDayName = DAYS[today.getDay()];
    const todayJalali = new Intl.DateTimeFormat('fa-IR', { year: 'numeric', month: 'numeric', day: 'numeric' }).format(today);
    
    daySelect.value = todayDayName;
    currentDateString = `تاریخ ${todayJalali}`;
    
    timeStart.value = today.getHours().toString().padStart(2, '0') + ':' + today.getMinutes().toString().padStart(2, '0');

    initSettings();
    render();
    if(timerInterval) clearInterval(timerInterval);
    startLiveTimer(); 
}

function generateTableSelect() {
    tableSelect.innerHTML = '';
    for(let i = 1; i <= TOTAL_TABLES; i++) {
        if(!TABLE_CONFIGS[i]) TABLE_CONFIGS[i] = { console: 'PS4', isVip: false };
        let config = TABLE_CONFIGS[i];
        let label = `میز ${i} (${config.console}${config.isVip ? ' - VIP 👑' : ''})`;
        tableSelect.appendChild(new Option(label, "میز " + i));
    }
}

function updateTableCount() {
    let val = parseInt(document.getElementById('tableCountInput').value);
    if(val > 0) {
        TOTAL_TABLES = val;
        for(let i=1; i<=TOTAL_TABLES; i++) {
            if(!TABLE_CONFIGS[i]) TABLE_CONFIGS[i] = { console: 'PS4', isVip: false };
        }
        generateTableSelect();
        renderTableSettings();
        saveSettingsToStorage(); 
    }
}

function initSettings() {
    let tableCountEl = document.getElementById('tableCountInput');
    if (tableCountEl) tableCountEl.value = TOTAL_TABLES;
    
    if(document.getElementById('p4_1')) {
        document.getElementById('p4_1').value = PRICING["PS4"]["1 دسته"];
        document.getElementById('p4_2').value = PRICING["PS4"]["2 دسته"];
        document.getElementById('p4_3').value = PRICING["PS4"]["3 دسته"];
        document.getElementById('p4_4').value = PRICING["PS4"]["4 دسته"];

        document.getElementById('p5_1').value = PRICING["PS5"]["1 دسته"];
        document.getElementById('p5_2').value = PRICING["PS5"]["2 دسته"];
        document.getElementById('p5_3').value = PRICING["PS5"]["3 دسته"];
        document.getElementById('p5_4').value = PRICING["PS5"]["4 دسته"];
    }

    if(document.getElementById('xbox_1')) {
        document.getElementById('xbox_1').value = PRICING["Xbox"]["1 دسته"];
        document.getElementById('xbox_2').value = PRICING["Xbox"]["2 دسته"];
        document.getElementById('xbox_3').value = PRICING["Xbox"]["3 دسته"];
        document.getElementById('xbox_4').value = PRICING["Xbox"]["4 دسته"];
    }

    if(document.getElementById('pc_1')) {
        document.getElementById('pc_1').value = PRICING["PC"]["معمولی"];
        document.getElementById('pc_2').value = PRICING["PC"]["VIP"];
    }

    if(document.getElementById('vip_1')) {
        document.getElementById('vip_1').value = PRICING["VIP"]["1 دسته"];
        document.getElementById('vip_2').value = PRICING["VIP"]["2 دسته"];
        document.getElementById('vip_3').value = PRICING["VIP"]["3 دسته"];
        document.getElementById('vip_4').value = PRICING["VIP"]["4 دسته"];
    }

    renderCafeMenus();
    renderTableSettings();
}

function updateGamePrices() {
    if(!document.getElementById('p4_1')) return;
    
    PRICING["PS4"]["1 دسته"] = parseInt(document.getElementById('p4_1').value) || 0;
    PRICING["PS4"]["2 دسته"] = parseInt(document.getElementById('p4_2').value) || 0;
    PRICING["PS4"]["3 دسته"] = parseInt(document.getElementById('p4_3').value) || 0;
    PRICING["PS4"]["4 دسته"] = parseInt(document.getElementById('p4_4').value) || 0;

    PRICING["PS5"]["1 دسته"] = parseInt(document.getElementById('p5_1').value) || 0;
    PRICING["PS5"]["2 دسته"] = parseInt(document.getElementById('p5_2').value) || 0;
    PRICING["PS5"]["3 دسته"] = parseInt(document.getElementById('p5_3').value) || 0;
    PRICING["PS5"]["4 دسته"] = parseInt(document.getElementById('p5_4').value) || 0;

