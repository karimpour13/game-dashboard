// ==== تابع اصلاح شده startLiveTimer ====
function startLiveTimer() {
    // پاک کردن تایمر قبلی برای جلوگیری از تداخل
    if (typeof timerInterval !== 'undefined' && timerInterval !== null) {
        clearInterval(timerInterval);
    }

    timerInterval = setInterval(() => {
        let day = daySelect.value;
        if(!gameNet[day]) return;
        
        gameNet[day].forEach((s, i) => {
            try {
                if(s.status === 'active') {
                    let startMs = s.startTimeMs || getStartTimeMs(s.timeStart);
                    let diffSeconds = Math.floor((Date.now() - startMs) / 1000);
                    if(diffSeconds < 0) diffSeconds = 0;
                    
                    let hrs = Math.floor(diffSeconds / 3600).toString().padStart(2,'0');
                    let mins = Math.floor((diffSeconds % 3600) / 60).toString().padStart(2,'0');
                    let secs = (diffSeconds % 60).toString().padStart(2,'0');
                    
                    let timerEl = document.getElementById(`timer_${i}`);
                    if(timerEl) timerEl.innerText = `${hrs}:${mins}:${secs}`;
                    
                    let costEl = document.getElementById(`live_cost_${i}`);
                    if(costEl) {
                        let hours = Math.max(1, diffSeconds / 3600);
                        let tableNum = parseInt(s.table.replace("میز ", ""));
                        let isVip = TABLE_CONFIGS[tableNum] ? TABLE_CONFIGS[tableNum].isVip : false;
                        
                        // اضافه شدن شرط برای جلوگیری از خطای undefined
                        let basePrice = 0;
                        if (isVip && PRICING["VIP"] && PRICING["VIP"][s.mode]) {
                            basePrice = PRICING["VIP"][s.mode];
                        } else if (PRICING[s.consoleType] && PRICING[s.consoleType][s.mode]) {
                            basePrice = PRICING[s.consoleType][s.mode];
                        }
                        
                        let gameCost = Math.round(hours * basePrice);
                        let cafeCost = s.cafeCost || 0;
                        costEl.innerHTML = `<small>کافه: ${cafeCost.toLocaleString()}</small><br><b>بازی: ${gameCost.toLocaleString()}</b>`;
                    }
                } 
                else if (s.status === 'reserved') {
                    let reserveMs = getReserveTimeMs(s.timeStart);
                    let diffSeconds = Math.floor((reserveMs - Date.now()) / 1000);
                    let timerEl = document.getElementById(`timer_${i}`);
                    if(timerEl) {
                        if(diffSeconds > 0) {
                            let hrs = Math.floor(diffSeconds / 3600).toString().padStart(2,'0');
                            let mins = Math.floor((diffSeconds % 3600) / 60).toString().padStart(2,'0');
                            let secs = (diffSeconds % 60).toString().padStart(2,'0');
                            timerEl.innerText = `⏳ ${hrs}:${mins}:${secs}`;
                            timerEl.className = 'live-timer reserved';
                        } else {
                            timerEl.innerText = '⚠️ زمان رزرو رسید!';
                            timerEl.className = 'live-timer warning';
                        }
                    }
                }
            } catch (error) {
                console.error("Error updating timer for session", i, error);
            }
        });
    }, 1000);
}
