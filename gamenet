function getStartTimeMs(timeStr) {
    let [h, m] = timeStr.split(':').map(Number);
    let d = new Date();
    d.setHours(h, m, 0, 0);
    if (d > new Date()) d.setDate(d.getDate() - 1); 
    return d.getTime();
}

function getReserveTimeMs(timeStr) {
    let [h, m] = timeStr.split(':').map(Number);
    let d = new Date();
    d.setHours(h, m, 0, 0);
    return d.getTime();
}

function calculateCost(startStr, endStr, consoleType, mode, totalCafe, tableStr) {
    let sm = parseTime(startStr), em = parseTime(endStr);
    if (em <= sm) em += 24 * 60;

    let actualHours = (em - sm) / 60;
    let costHours = Math.max(1, actualHours);
    
    let tableNum = parseInt(tableStr.replace("میز ", ""));
    let isVip = TABLE_CONFIGS[tableNum] ? TABLE_CONFIGS[tableNum].isVip : false;
    let basePrice = isVip ? PRICING["VIP"][mode] : PRICING[consoleType][mode];

    return {
        durationStr: actualHours.toFixed(2),
        gameCost: Math.round(costHours * basePrice),
        total: Math.round(costHours * basePrice) + totalCafe
    };
}

function parseTime(timeStr) {
    let [h, m] = timeStr.split(':').map(Number);
    return h * 60 + m;
}

function isTableActive(day, table) {
    return gameNet[day].some(s => s.table === table && s.status === 'active');
}

