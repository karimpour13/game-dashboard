<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>سامانه مدیریت گیم‌نت</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    
     <Style>
        /* ================== فونت محلی ================== */
@font-face {
    font-family: 'PortadaARA';
    /* فایل PortadaARA-Bold.otf با توجه به آدرس شما دقیقا کنار همین فایل style.css قرار دارد */
    src: url('PortadaARA-Bold.otf') format('opentype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
}

:root {
    --bg-color: #0f0f13;
    --panel-bg: #1a1a24;
    --primary: #00f3ff;
    --secondary: #bc13fe;
    --warning: #ff0055;
    --success: #00ff66;
    --text-main: #ffffff;
    --text-muted: #8892b0;
    --border-glow: 0 0 10px rgba(0, 243, 255, 0.3);
    --input-bg: rgba(0, 0, 0, 0.3);
    --th-bg: rgba(0, 0, 0, 0.2);
}

/* تم روشن */
[data-theme="light"] {
    --bg-color: #f4f4f9;
    --panel-bg: #ffffff;
    --primary: #0066cc;
    --secondary: #8a2be2;
    --warning: #e6004c;
    --success: #009933;
    --text-main: #111;
    --text-muted: #555;
    --border-glow: 0 0 10px rgba(0, 102, 204, 0.3);
    --input-bg: #f9f9f9;
    --th-bg: #eaeaea;
}

* { box-sizing: border-box; margin: 0; padding: 0; font-family: 'PortadaARA', sans-serif; }

body {
    background-color: var(--bg-color); color: var(--text-main); min-height: 100vh;
    background-image: radial-gradient(circle at 15% 50%, rgba(188, 19, 254, 0.05), transparent 25%),
                      radial-gradient(circle at 85% 30%, rgba(0, 243, 255, 0.05), transparent 25%);
    transition: background-color 0.3s, color 0.3s;
}

/* ================== استایل‌های صفحه لاگین جدید ================== */
#loginScreen {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 9999;
    display: flex; align-items: center; justify-content: center;
}

.login-video-bg {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    object-fit: cover; z-index: -2;
}

.login-overlay {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.65); z-index: -1;
}

.login-wrapper {
    width: 100%; padding: 30px 20px; display: flex; justify-content: center;
}

.glass-login-box {
    max-width: 480px; width: 100%; background: rgba(255,255,255,0.08); backdrop-filter: blur(12px);
    border-radius: 20px; padding: 40px 35px; box-shadow: 0 25px 45px rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.15); transition: all 0.3s ease;
}

.logo-area { text-align: center; margin-bottom: 30px; }
.logo-area img { max-width: 100px; border-radius: 20px; }
.logo-area h2 { font-size: 26px; margin-top: 15px; font-weight: 500; letter-spacing: -0.5px; color: #fff; background: none; -webkit-text-fill-color: #fff; text-shadow: none;}
.logo-area p { color: rgba(255,255,255,0.7); font-size: 14px; }

.wd-form { width: 100%; }
.login-form-row { margin-bottom: 20px; text-align: right;}
.login-form-row label { display: block; margin-bottom: 8px; font-weight: 500; font-size: 14px; color: #eaeaea; }
.login-form-row input {
    width: 100%; padding: 14px 18px; background: rgba(255,255,255,0.1) !important; 
    border: 1px solid rgba(255,255,255,0.2) !important; border-radius: 40px !important;
    color: white !important; font-size: 15px; outline: none; transition: 0.2s; text-align: right !important; box-shadow: none !important;
}
.login-form-row input:focus {
    border-color: #00bcd4 !important; background: rgba(255,255,255,0.15) !important;
    box-shadow: 0 0 0 3px rgba(0,188,212,0.2) !important;
}
.login-form-row input::placeholder { color: rgba(255,255,255,0.5); }

.form-actions { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; font-size: 14px; color:#fff;}
.remember-me { display: flex; align-items: center; gap: 8px; }
.remember-me input { width: 18px; height: 18px; accent-color: #00bcd4; margin: 0; }
.forgot-link a { color: #00bcd4; text-decoration: none; font-weight: 500; }
.forgot-link a:hover { text-decoration: underline; }

.btn-login {
    width: 100%; background: #00bcd4; border: none; padding: 14px; border-radius: 40px;
    font-size: 16px; font-weight: 600; color: #fff; cursor: pointer; transition: 0.2s; margin-bottom: 20px; text-align: center;
}
.btn-login:hover { background: #00acc1; transform: translateY(-2px); box-shadow: 0 10px 20px rgba(0,188,212,0.3); }

.register-link { text-align: center; font-size: 14px; color: rgba(255,255,255,0.7); }
.register-link a { color: #00bcd4; text-decoration: none; font-weight: 600; }
.register-link a:hover { text-decoration: underline; }

@media (max-width: 550px) {
    .glass-login-box { padding: 30px 20px; }
    .form-actions { flex-direction: column; gap: 12px; align-items: flex-start; }
}

/* ================== استایل‌های سامانه اصلی ================== */
#appScreen { display: none; padding: 20px;}

.header-top { display: flex; justify-content: space-between; align-items: center; max-width: 1400px; margin: 0 auto 15px auto; }
.header-right, .header-left { display: flex; gap: 10px; align-items: center; }

.layout-grid { max-width: 1400px; margin: 0 auto; }

.container {
    background: var(--panel-bg); border-radius: 15px; padding: 25px;
    box-shadow: 0 0 20px rgba(0, 0, 0, 0.5), inset 0 0 0 1px rgba(255, 255, 255, 0.05);
    transition: box-shadow 0.3s ease, background 0.3s; position: relative; overflow: hidden;
}
.container::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--primary), var(--secondary));
}

h1, h2, h3 { 
    text-align: center; margin-bottom: 25px; font-weight: 800; 
    background: linear-gradient(to right, var(--primary), var(--secondary)); 
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; 
    text-shadow: 0 0 20px rgba(0, 243, 255, 0.2); 
}
h2 { font-size: 1.5rem; margin-bottom: 20px; }

.form-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 15px; margin-bottom: 25px; }
.input-group { display: flex; flex-direction: column; gap: 8px; }
.input-group label { font-size: 0.9rem; color: var(--text-muted); }

select, input[type="time"], input[type="number"], .container input[type="text"] {
    background: var(--input-bg); border: 1px solid rgba(150, 150, 150, 0.2); width: 100%;
    color: var(--text-main); padding: 12px; border-radius: 8px; outline: none; transition: all 0.3s;
}
select:focus, input[type="time"]:focus, input[type="number"]:focus, .container input[type="text"]:focus { border-color: var(--primary); box-shadow: 0 0 10px rgba(0, 243, 255, 0.2); }

.btn { padding: 12px 20px; border: none; border-radius: 8px; cursor: pointer; font-weight: bold; transition: all 0.3s; color: white; text-align: center;}
.btn-primary { background: linear-gradient(45deg, #0055ff, var(--primary)); box-shadow: 0 4px 15px rgba(0, 243, 255, 0.3); }
.btn-primary:hover { box-shadow: 0 0 20px var(--primary); transform: translateY(-2px); }
.btn-danger { background: linear-gradient(45deg, #a00, var(--warning)); box-shadow: 0 4px 15px rgba(255, 0, 85, 0.3); padding: 8px 12px; font-size: 0.8rem; }
.btn-danger:hover { box-shadow: 0 0 20px var(--warning); }
.btn-success { background: linear-gradient(45deg, #00aa55, var(--success)); box-shadow: 0 4px 15px rgba(0, 255, 102, 0.3); padding: 6px 10px; font-size: 0.8rem; color: #fff; }
.btn-cafe { background: linear-gradient(45deg, #5500aa, var(--secondary)); box-shadow: 0 4px 15px rgba(188, 19, 254, 0.3); padding: 6px 10px; font-size: 0.8rem; margin-top: 5px; width: 100%;}
.btn-settings { background: linear-gradient(45deg, #5500aa, var(--secondary)); box-shadow: 0 4px 15px rgba(188, 19, 254, 0.3); width: 100%; margin-top: 10px; }

.btn-top { background: var(--panel-bg); color: var(--text-main); border: 1px solid var(--primary); box-shadow: 0 0 10px rgba(0,243,255,0.2); padding: 8px 15px;}
.btn-excel { border-color: var(--success); color: var(--success); box-shadow: 0 0 10px rgba(0,255,102,0.2); }
.btn-excel:hover { background: rgba(0,255,102,0.1); }

.summary-bar { display: flex; justify-content: space-between; align-items: center; background: rgba(150, 150, 150, 0.05); padding: 15px; border-radius: 8px; margin-bottom: 20px; border-right: 3px solid var(--secondary); flex-wrap: wrap; gap: 10px; }
.stat-box { display: flex; align-items: center; gap: 10px; }
.stat-value { font-size: 1.1rem; font-weight: bold; color: var(--primary); text-shadow: 0 0 10px rgba(0, 243, 255, 0.5); }

table { width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 0.95rem; }
th, td { padding: 12px; text-align: right; border-bottom: 1px solid rgba(150, 150, 150, 0.1); vertical-align: middle; }
th { background: var(--th-bg); color: var(--text-muted); font-weight: normal; }

.row-active { border-right: 4px solid var(--success); background: rgba(0, 255, 102, 0.02); }
.row-closed { border-right: 4px solid var(--warning); background: rgba(255, 0, 85, 0.08); }
.row-closed td { color: var(--text-muted); }
.row-closed:hover { background: rgba(255, 0, 85, 0.15); }

/* استایل‌های مربوط به رزرو */
.row-reserved { border-right: 4px solid var(--primary); background: rgba(0, 243, 255, 0.05); }
.live-timer.reserved { color: var(--primary); text-shadow: 0 0 5px rgba(0, 243, 255, 0.5); font-size: 1.1rem;}
.live-timer.warning { color: var(--warning); text-shadow: 0 0 5px rgba(255, 0, 85, 0.5); animation: blink 1s infinite; }
@keyframes blink { 50% { opacity: 0.5; } 100% { opacity: 1; } }

/* ================== استایل‌های اختصاصی VIP ================== */
.row-vip { 
    background-image: linear-gradient(to left, rgba(255, 215, 0, 0.08), transparent) !important;
}
.badge-vip { 
    background: rgba(255, 215, 0, 0.15); 
    color: #ffd700; 
    border: 1px solid #ffd700; 
    text-shadow: 0 0 8px rgba(255, 215, 0, 0.4); 
    margin-right: 6px; 
    padding: 3px 8px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: bold;
    display: inline-block;
}
.text-gold {
    color: #ffd700;
    text-shadow: 0 0 5px rgba(255, 215, 0, 0.5);
}

.badge { padding: 4px 10px; border-radius: 20px; font-size: 0.8rem; font-weight: bold; display: inline-block; margin-bottom: 3px;}
.badge-table { background: rgba(0, 243, 255, 0.1); color: var(--primary); border: 1px solid var(--primary); }
.badge-mode { background: rgba(188, 19, 254, 0.1); color: var(--secondary); border: 1px solid var(--secondary); }
.badge-cafe { background: rgba(0, 255, 102, 0.1); color: var(--success); border: 1px solid var(--success); font-size: 0.75rem; margin-left: 2px;}

/* ================== استایل‌های مربوط به پاپ‌آپ‌ها (مودال‌ها) ================== */
.settings-panel { background: rgba(150,150,150,0.05); padding: 15px; border-radius: 10px; border: 1px dashed rgba(150,150,150,0.3); margin-top: 20px;}
.cafe-item-row { display: flex; justify-content: space-between; align-items: center; background: rgba(150,150,150,0.05); padding: 8px 12px; border-radius: 5px; margin-bottom: 8px; font-size: 0.9rem; }

.modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 2000; justify-content: center; align-items: center; }

.cafe-row { display: flex; justify-content: space-between; align-items: center; background: rgba(150,150,150,0.05); padding: 8px; border-radius: 5px;}
.cafe-row input { width: 60px; padding: 5px; text-align: center;}

.live-timer { font-size: 1.2rem; font-weight: bold; color: var(--success); letter-spacing: 2px; text-shadow: 0 0 5px rgba(0,255,102,0.5); direction: ltr; display: inline-block;}

.price-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; margin-bottom: 15px; }
.price-grid .input-group { display: flex; flex-direction: column; align-items: center; }
.price-grid input { text-align: center; font-weight: bold; letter-spacing: 1px; padding: 10px; }
.price-label { font-size: 0.85rem; color: var(--text-main); margin-bottom: 5px; }

/* ================== استایل‌های مودال هماهنگ با تم سایت ================== */
#reserveModal .modal-content {
    background-color: var(--panel-bg);
    border: 1px solid var(--primary);
    box-shadow: 0 0 30px rgba(0, 243, 255, 0.2);
}

#reserveModal h3 {
    margin-bottom: 20px;
}

/* استایل‌های یکپارچه برای ورودی‌های تمام مودال‌ها */
#reserveModal input, 
#reserveModal select, 
#reserveModal textarea,
#tablesSettingsModal input,
#pricesSettingsModal input,
#manageCafeModal input,
.modal-content input, 
.modal-content select, 
.modal-content textarea {
    background-color: var(--input-bg);
    color: var(--text-main);
    border: 1px solid rgba(150, 150, 150, 0.2);
    border-radius: 8px;
    padding: 12px;
    width: 100%;
    margin-bottom: 10px;
    outline: none;
    transition: all 0.3s ease;
    font-family: inherit;
}

/* افکت هنگام کلیک کردن (Focus) روی کادرهای ورودی */
#reserveModal input:focus, 
#reserveModal select:focus,
#reserveModal textarea:focus,
#tablesSettingsModal input:focus,
#pricesSettingsModal input:focus,
#manageCafeModal input:focus,
.modal-content input:focus, 
.modal-content select:focus,
.modal-content textarea:focus {
    border-color: var(--primary);
    box-shadow: 0 0 10px rgba(0, 243, 255, 0.2);
}

/* ================== استایل اختصاصی برای دکمه تنظیمات سیستم ================== */
.btn-settings-blue {
    background-color: var(--primary);
    color: var(--bg-color); 
    border: 1px solid var(--primary);
    box-shadow: 0 0 8px rgba(0, 243, 255, 0.4); 
    transition: all 0.3s ease;
    padding: 8px 15px;
    border-radius: 8px;
    font-weight: bold;
    cursor: pointer;
}

.btn-settings-blue:hover {
    background-color: transparent; 
    color: var(--primary); 
    box-shadow: 0 0 15px rgba(0, 243, 255, 0.8); 
}

/* ================== استایل‌های گرید کارتی تنظیمات میزها (بازطراحی) ================== */
#tableSettingsList {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: 15px;
    padding: 10px 0;
}

.table-setting-card {
    background: var(--input-bg);
    border: 1px solid rgba(150, 150, 150, 0.2);
    border-radius: 12px;
    padding: 15px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}

.table-setting-card:hover {
    border-color: var(--primary);
    box-shadow: 0 5px 15px rgba(0, 243, 255, 0.15);
    transform: translateY(-2px);
}

.table-setting-header {
    font-weight: bold;
    color: var(--primary);
    text-align: center;
    margin-bottom: 5px;
    font-size: 1.1rem;
    text-shadow: 0 0 5px rgba(0, 243, 255, 0.2);
}

.table-setting-select {
    background: var(--panel-bg);
    border: 1px solid rgba(150, 150, 150, 0.3);
    color: var(--text-main);
    padding: 8px;
    border-radius: 6px;
    width: 100%;
    text-align: center;
    outline: none;
    cursor: pointer;
    font-size: 0.9rem;
    margin-bottom: 0 !important;
}

.table-setting-select:focus {
    border-color: var(--primary);
}

.vip-toggle-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: rgba(255, 215, 0, 0.1);
    padding: 8px;
    border-radius: 6px;
    cursor: pointer;
    border: 1px solid transparent;
    transition: all 0.3s;
}

.vip-toggle-wrapper:hover {
    border-color: rgba(255, 215, 0, 0.4);
    background: rgba(255, 215, 0, 0.15);
}

.vip-toggle-wrapper input[type="checkbox"] {
    width: 16px !important;
    height: 16px !important;
    accent-color: #ffd700;
    cursor: pointer;
    margin: 0 !important;
}

.vip-toggle-wrapper span {
    color: #ffd700;
    font-size: 0.85rem;
    font-weight: bold;
    text-shadow: 0 0 5px rgba(255, 215, 0, 0.3);
}

/* ================== تغییرات جدید: مخفی کردن اسکرول‌بار و بزرگ کردن پاپ‌آپ ================== */

/* استایل اصلی مودال‌ها با قابلیت مخفی شدن اسکرول‌بار */
.modal-content { 
    background: var(--panel-bg); 
    padding: 25px; 
    border-radius: 15px; 
    border: 1px solid var(--secondary); 
    width: 380px; 
    max-width: 95vw; 
    box-shadow: 0 0 30px rgba(188, 19, 254, 0.3); 
    max-height: 95vh; 
    overflow-y: auto; 
    
    /* مخفی کردن اسکرول‌بار برای فایرفاکس و اینترنت اکسپلورر */
    scrollbar-width: none; 
    -ms-overflow-style: none; 
}

/* مخفی کردن کامل اسکرول‌بار در کروم، سافاری و اپرا */
.modal-content::-webkit-scrollbar {
    display: none;
}

/* بزرگ‌تر کردن پاپ‌آپ تنظیمات میزها برای چیده شدن کارت‌ها در کنار هم */
#tablesSettingsModal .modal-content {
    width: 800px; 
}

/* بزرگ‌تر کردن پاپ‌آپ تعرفه ساعتی و کافه */
#pricesSettingsModal .modal-content,
#manageCafeModal .modal-content {
    width: 450px; 
}

/* مخفی کردن اسکرول برای لیست‌های داخلی مثل منوی کافه */
.cafe-options-modal { 
    max-height: 350px; 
    overflow-y: auto; 
    display: flex; 
    flex-direction: column; 
    gap: 10px; 
    margin-bottom: 20px; 
    
    scrollbar-width: none; 
    -ms-overflow-style: none; 
}
.cafe-options-modal::-webkit-scrollbar {
    display: none;
}

     </Style>
</head>
<body>

<!-- ================== صفحه لاگین ================== -->
<div id="loginScreen">
   <img class="login-video-bg" src="back.png" alt="background">

    <div class="login-overlay"></div>

    <div class="login-wrapper">
        <div class="glass-login-box">
            <div class="logo-area">
                <img src="لوگو.webp" alt="مهام وب">
                <h2>ورود به حساب کاربری</h2>
                <p>به خانواده مهام وب خوش آمدید</p>
            </div>

            <div class="wd-form">
                <div class="login-form-row">
                    <label><i class="fas fa-user"></i>  نام کاربری یا ایمیل</label>
                    <input type="text" id="loginUsername" placeholder="نام کابری" required>
                </div>
                <div class="login-form-row">
                    <label><i class="fas fa-lock"></i>  رمز عبور</label>
                    <input type="password" id="loginPassword" placeholder="••••••••" required>
                </div>

                <div class="form-actions">
                    <label class="remember-me">
                        <input type="checkbox" name="remember"> مرا به خاطر بسپار
                    </label>
                    <div class="forgot-link">
                        <a href="#">رمز عبور را فراموش کرده‌اید؟</a>
                    </div>
                </div>

                <button type="button" class="btn-login" onclick="checkLogin()">ورود به حساب</button>

                <div class="register-link">
                    حساب کاربری ندارید؟ <a href="#">ثبت‌نام کنید</a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ================== بدنه اصلی سامانه ================== -->
<div id="appScreen">
    <div class="header-top">
        <div class="header-right">
           <!-- سه دکمه مجزا جایگزین دکمه تنظیمات کلی شدند -->
           <button class="btn btn-top btn-settings-blue" onclick="openSettingsModal('tablesSettingsModal')">⚙️ تنظیمات کلی میزها</button>
           <button class="btn btn-top btn-settings-blue" onclick="openSettingsModal('pricesSettingsModal')">💰 تعرفه پایه ساعتی</button>
           <button class="btn btn-top btn-settings-blue" onclick="openSettingsModal('manageCafeModal')">☕ مدیریت کافه و انبار</button>
        </div>
        <div class="header-left">
            <button class="btn btn-top btn-excel" onclick="exportToExcel()">📊 خروجی اکسل روزانه</button>
            <button class="btn btn-top" onclick="toggleTheme()">☀️ / 🌙 تغییر تم</button>
            <button class="btn btn-top" style="border-color: var(--warning); color: var(--warning);" onclick="logout()">خروج 🚪</button>
        </div>
    </div>

    <div class="layout-grid">
        <div class="container" id="mainContainer">
            <h1>سامانه مدیریت گیم‌نت گیم لند</h1>
            
            <div class="form-grid">
                <div class="input-group">
                    <label>روز هفته</label>
                    <select id="daySelect"></select>
                </div>
                <div class="input-group">
                    <label>شماره میز</label>
                    <select id="tableSelect"></select>
                </div>
                <div class="input-group">
                    <label>حالت بازی</label>
                    <select id="modeSelect">
                        <option value="1 دسته">1 دسته</option>
                        <option value="2 دسته" selected>2 دسته</option>
                        <option value="3 دسته">3 دسته</option>
                        <option value="4 دسته">4 دسته</option>
